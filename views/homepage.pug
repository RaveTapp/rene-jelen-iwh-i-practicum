doctype html
html 
    head 
        title= `${title}`
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body    
        h1 Homepage
        a(href="/update-cobj") Add to this table

        table.objects-table
            thead
                tr
                    th Name
                    th Email
                    th Favorite Movie
                    th Preferred Communication
                    th Bio
            tbody
                each contact in data
                    tr
                        td= `${contact.properties.firstname} ${contact.properties.lastname}`
                        td= contact.properties.email
                        td= contact.properties.favorite_movie
                        td= contact.properties.preferred_communication
                        td= contact.properties.bio